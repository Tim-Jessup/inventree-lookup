{
  "manifest_version": 2,
  "name": "InvenTree Item Lookup",
  "version": "1.1",
  "description": "Quick access to Currawong part numbers, orders, and more in InvenTree",
  "browser_specific_settings": {
    "gecko": {
      "id": "inventree-lookup@currawong",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "permissions": [
    "contextMenus",
    "storage",
    "tabs",
    "activeTab",
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "omnibox": {
    "keyword": "inv"
  },
  "commands": {
    "_execute_browser_action": {
      "suggested_key": {
        "default": "Alt+I",
        "mac": "Alt+I"
      },
      "description": "Activate InvenTree Lookup extension"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
